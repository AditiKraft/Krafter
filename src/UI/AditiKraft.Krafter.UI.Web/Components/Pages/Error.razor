@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div style="display: flex; align-items: center; justify-content: center; min-height: 80vh; padding: 2rem;">
    <div style="text-align: center; max-width: 500px;">
        <RadzenIcon Icon="error_outline" Style="font-size: 5rem; color: var(--rz-danger);" />
        <RadzenText TextStyle="TextStyle.DisplayH4" TagName="TagName.H1" class="rz-mt-4" Style="color: var(--rz-danger);">
            Something went wrong
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body1" class="rz-mt-2" Style="color: var(--rz-text-secondary-color);">
            An unexpected error occurred while processing your request. Please try again.
        </RadzenText>

        @if (ShowRequestId)
        {
            <RadzenText TextStyle="TextStyle.Caption" class="rz-mt-4" Style="color: var(--rz-text-disabled-color);">
                Request ID: @RequestId
            </RadzenText>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center" Gap="1rem" class="rz-mt-6">
            <RadzenButton Text="Go Home" Icon="home" ButtonStyle="ButtonStyle.Primary"
                          Click="@(() => NavigationManager.NavigateTo("/"))" />
            <RadzenButton Text="Try Again" Icon="refresh" ButtonStyle="ButtonStyle.Light"
                          Click="@(() => NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true))" />
        </RadzenStack>
    </div>
</div>

@code {
    [CascadingParameter] private HttpContext? HttpContext { get; set; }
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized()
    {
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }
}
