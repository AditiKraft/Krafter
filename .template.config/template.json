{
  "$schema": "http://json.schemastore.org/template",
  "author": "Aditi Kraft",
  "classifications": [
    "Web",
    "ASP.NET",
    "Blazor",
    "Full-Stack",
    "Vertical Slice Architecture"
  ],
  "identity": "AditiKraft.Krafter.FullStack.Template",
  "name": "AditiKraft Krafter Full-Stack Application (Split Host)",
  "shortName": "krafter",
  "description": "A full-stack .NET 10 template with separate Backend API and Blazor UI hosts. Uses ASP.NET Core Minimal APIs (VSA), Blazor Hybrid, .NET Aspire, and PostgreSQL.",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sourceName": "AditiKraft.Krafter",
  "preferNameDirectory": true,
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            ".git/**",
            ".vs/**",
            ".idea/**",
            "**/bin/**",
            "**/obj/**",
            "**/*.user",
            "**/.DS_Store",
            ".nuke/temp/**",
            ".template.config/**",
            ".template.config-single/**",
            "src-single/**",
            "aspire-single/**",
            "AditiKraft.Krafter.Single.slnx",
            "AditiKraft.Krafter.Dev.slnx",
            "AditiKraft.Krafter.Templates.csproj",
            "pack-and-install.cmd",
            "Agents.md",
            "Agents.single.md"
          ]
        }
      ],
      "rename": {
        "Agents.split.md": "Agents.md"
      }
    }
  ],
  "postActions": [
    {
      "description": "Restore NuGet packages",
      "manualInstructions": [
        {
          "text": "Run 'dotnet restore'"
        }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ]
}
